flowchart TD
  A1[Resume Upload] --> A2[Extract Prompt Runs]
  A2 --> A3[Parsed Roles Snapshot: title/company/dates/months]
  A3 --> A4[Stored on Resume - reused in future runs]

  B1[Choose Run Settings: model/blind mode/rules/evidence instructions/fn defs] --> B2[Label Roles by Variant: function labels + supporting evidence candidates]
  B2 --> B3[Canonical Evidence Selection]
  B3 --> B4[Aggregate Months per Function Label: dedupe role+label]
  B4 --> B5[Persist Run + Variant Rows: research_runs + research_run_results]

  A4 --> B1

  B5 --> C1[Run Screen: Dot Grid + Function Outputs]
  B5 --> C2[Review Queue: evidence rating + missed evidence flags]
  C2 --> C3[Finalize Review: draft/finalized, reviewer+timestamp, coverage]
  C3 --> C4[Data/Viz Tab: accuracy metrics + filters]

  D1[Deleted runs hidden by default] --> C4
  D2[Only finalized reviewed data counts in analytics] --> C4
  D3[Canonical evidence parity rule: Run and Review use same source] --> C1
  D3 --> C2

  V1{"Variable: Extract Prompt"} -.controls.-> A2
  V2{"Variable: Prompt Components rules/evidence/fn defs"} -.controls.-> B2
  V3{"Variable: Evidence Selection Preset strict/balanced/website/broad"} -.controls.-> B3
  V4{"Variable: Review State + Coverage Gate"} -.controls.-> C3

  classDef process fill:#ffffff,stroke:#94a3b8,stroke-width:1.8,color:#0f172a;
  classDef variable fill:#f5f3ff,stroke:#7c3aed,stroke-width:2,color:#4c1d95;
  classDef governance fill:#f8fafc,stroke:#64748b,stroke-width:1.6,color:#334155;

  class A1,A2,A3,A4,B1,B2,B3,B4,B5,C1,C2,C3,C4 process;
  class V1,V2,V3,V4 variable;
  class D1,D2,D3 governance;
